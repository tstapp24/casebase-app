# Steam Web API Key
# Get yours at: https://steamcommunity.com/dev/apikey
# On first launch, enter this key in the Settings panel — it will be encrypted
# via Electron safeStorage and stored securely in the OS keychain.
# NEVER put your real key here or commit it to source control.
STEAM_API_KEY=your_steam_api_key_here

# Optional: set to 'development' for verbose logging
NODE_ENV=production
